{
  "name": "sound-alert-yooo",
  "displayName": "sound-alert-yooo",
  "description": "Plays a sound whenever a code error is detected",
  "version": "0.1.0",
  "publisher": "g-poorna",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.jpg",
  "repository": {
    "type": "git",
    "url": "https://github.com/poorna1chandra/sound-alert-faah"
  },
  "main": "./out/extension.js",
